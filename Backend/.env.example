# PrintApp Backend Environment Variables
# =====================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Xerox WebSocket Authentication Key (REQUIRED)
# Generate using: python -c "import secrets; print(secrets.token_hex(32))"
XEROX_API_KEY=your-secure-key-here

# Allowed CORS Origins (comma-separated)
# Production example: https://your-app.com
ALLOWED_ORIGINS=*

# Debug Mode (disable in production)
DEBUG_MODE=false
